# VoxType Configuration (Developer Quick-Start)
# Copy to .env and fill in your API keys.
#   cp .env.example .env
#
# Having .env skips the Settings panel onboarding.
# Otherwise, Settings auto-opens on first launch for GUI configuration.

# ---- Speech-to-Text Provider ----
# Provider: groq | openai | deepgram | local | custom
VOXTYPE_STT_PROVIDER=deepgram
VOXTYPE_STT_API_KEY=
VOXTYPE_STT_MODEL=nova-2
VOXTYPE_STT_LANGUAGE=zh
VOXTYPE_STT_BASE_URL=https://api.deepgram.com/v1

# ---- LLM Polish Provider ----
# Provider: openai | deepseek | anthropic | gemini | groq | ollama | custom
VOXTYPE_LLM_PROVIDER=deepseek
VOXTYPE_LLM_API_KEY=
VOXTYPE_LLM_MODEL=deepseek-chat
VOXTYPE_LLM_BASE_URL=https://api.deepseek.com/v1

# ---- Recommended Free/Low-Cost Setup ----
# STT:  Groq     whisper-large-v3-turbo  (free)     → https://console.groq.com/keys
# LLM:  DeepSeek deepseek-chat          (~$0.14/M)  → https://platform.deepseek.com
