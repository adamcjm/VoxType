# VoxType Configuration
# Copy this file to .env and fill in your API keys.
# cp .env.example .env

# ---- Speech-to-Text Provider ----
# Options: groq | openai | deepgram | local | custom
VOXTYPE_STT_PROVIDER=deepgram
VOXTYPE_STT_API_KEY=
VOXTYPE_STT_MODEL=nova-2
VOXTYPE_STT_LANGUAGE=zh
VOXTYPE_STT_BASE_URL=https://api.deepgram.com/v1

# ---- LLM Polish Provider ----
# Options: openai | deepseek | anthropic | gemini | groq | ollama | custom
VOXTYPE_LLM_PROVIDER=deepseek
VOXTYPE_LLM_API_KEY=
VOXTYPE_LLM_MODEL=deepseek-chat
VOXTYPE_LLM_BASE_URL=https://api.deepseek.com/v1
