{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxType",
  "version": "0.1.0",
  "identifier": "com.voxtype.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "capsule",
        "title": "VoxType",
        "width": 400,
        "height": 120,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "url": "/capsule"
      },
      {
        "label": "main",
        "title": "VoxType",
        "width": 640,
        "height": 520,
        "center": true,
        "visible": false,
        "url": "/main"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "VoxType - Voice Input"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [],
    "copyright": "MIT",
    "category": "Utilities",
    "shortDescription": "AI voice input for desktop",
    "longDescription": "VoxType is an open-source AI voice input tool for desktop — a Typeless alternative. Press a hotkey, speak naturally, and get polished text at your cursor in any app.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/adamcjm/VoxType/releases/latest/download/latest.json"
      ]
    }
  }
}
